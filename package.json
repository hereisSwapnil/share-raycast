{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "share-raycast",
  "title": "Share Local File",
  "description": "Share any file over local network with a QR code",
  "icon": "🌐",
  "author": "you",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Share File",
      "description": "Share a file over local network",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.77.1",
    "@raycast/utils": "^1.16.1",
    "mime-types": "^2.1.35",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/mime-types": "^2.1.4",
    "@types/node": "20.8.10",
    "@types/qrcode": "^1.5.5",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
